<?xml version="1.0" encoding="utf-8"?>
<manifest
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools">

	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.WAKE_LOCK" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="android.permission.VIBRATE" android:maxSdkVersion="18" />
	<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="22" />
	<uses-permission-sdk-23 android:name="android.permission.FOREGROUND_SERVICE" />
	<uses-permission-sdk-23 android:name="android.permission.SYSTEM_ALERT_WINDOW" />
	<uses-permission-sdk-23 android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
	<uses-permission-sdk-23 android:name="android.permission.REQUEST_DELETE_PACKAGES" />

	<queries>
		<!-- Keep this list in sync with known extension packages in build.gradle. -->
		<package android:name="com.mishiranu.dashchan.chan.archb4k" />
		<package android:name="com.mishiranu.dashchan.chan.archivedmoe" />
		<package android:name="com.mishiranu.dashchan.chan.archiveforplebs" />
		<package android:name="com.mishiranu.dashchan.chan.archiveofsins" />
		<package android:name="com.mishiranu.dashchan.chan.archiverbt" />
		<package android:name="com.mishiranu.dashchan.chan.arhivach" />
		<package android:name="com.mishiranu.dashchan.chan.bunbunmaru" />
		<package android:name="com.mishiranu.dashchan.chan.cirno" />
		<package android:name="com.mishiranu.dashchan.chan.desustorage" />
		<package android:name="com.mishiranu.dashchan.chan.dobrochan" />
		<package android:name="com.mishiranu.dashchan.chan.dollchan" />
		<package android:name="com.mishiranu.dashchan.chan.dvach" />
		<package android:name="io.dashchan2.chan.dvach" />
		<package android:name="io.dashchan2.chan.fourchan" />
		<package android:name="com.mishiranu.dashchan.chan.e444" />
		<package android:name="com.mishiranu.dashchan.chan.endchan" />
		<package android:name="com.mishiranu.dashchan.chan.erlach" />
		<package android:name="com.mishiranu.dashchan.chan.fourchan" />
		<package android:name="com.mishiranu.dashchan.chan.local" />
		<package android:name="com.mishiranu.dashchan.chan.moechannel" />
		<package android:name="com.mishiranu.dashchan.chan.nowere" />
		<package android:name="com.mishiranu.dashchan.chan.palanq" />
		<package android:name="com.mishiranu.dashchan.chan.palanqwin" />
		<package android:name="com.mishiranu.dashchan.chan.refugedobrochan" />
		<package android:name="com.mishiranu.dashchan.chan.sojakparty" />
		<package android:name="com.mishiranu.dashchan.chan.warosu" />
		<package android:name="com.mishiranu.dashchan.chan.yakujimoe" />
		<package android:name="com.mishiranu.dashchan.lib.webm" />
		<package android:name="com.mishiranu.dashchan.lib.webm.test" />
		<package android:name="com.trixiether.dashchan.chan.archb4k" />
		<package android:name="com.trixiether.dashchan.chan.archivedmoe" />
		<package android:name="com.trixiether.dashchan.chan.archiveforplebs" />
		<package android:name="com.trixiether.dashchan.chan.archiveofsins" />
		<package android:name="com.trixiether.dashchan.chan.palanq" />
		<package android:name="com.trixiether.dashchan.chan.refugedobrochan" />
		<package android:name="com.trixiether.dashchan.chan.warosu" />
	</queries>

	<application
		android:name=".content.MainApplication"
		android:label="${appLabel}"
		android:icon="@mipmap/ic_launcher"
		android:logo="@mipmap/ic_logo"
		android:theme="@style/Theme.Launcher"
		android:largeHeap="true"
		android:allowBackup="true"
		android:fullBackupContent="true"
		android:usesCleartextTraffic="true"
		tools:ignore="GoogleAppIndexingWarning,UnusedAttribute">

		<activity
			android:name=".ui.MainActivity"
			android:launchMode="singleTask">

			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<category android:name="android.intent.category.LAUNCHER" />
				<category android:name="android.intent.category.MULTIWINDOW_LAUNCHER" />
			</intent-filter>

			<intent-filter>
				<action android:name="chan.intent.action.HANDLE_URI" />
				<category android:name="android.intent.category.DEFAULT" />
				<data android:scheme="http" />
				<data android:scheme="https" />
			</intent-filter>

			<intent-filter>
				<action android:name="android.intent.action.VIEW" />
				<category android:name="android.intent.category.DEFAULT" />
				<category android:name="android.intent.category.BROWSABLE" />
				<data android:scheme="http" />
				<data android:scheme="https" />
				<data android:host="2ch.su" />
				<data android:host="2ch.org" />
				<data android:host="2ch.life" />
				<data android:host="2ch.hk" />
				<data android:host="2ch.pm" />
				<data android:host="2ch.cm" />
				<data android:host="2ch.re" />
				<data android:host="2ch.tf" />
				<data android:host="2ch.wf" />
				<data android:host="2ch.yt" />
				<data android:host="2-ch.so" />
			</intent-filter>

		</activity>

		<activity
			android:name=".content.PostingShareActivity"
			android:taskAffinity=".postingshare"
			android:launchMode="singleInstance"
			android:excludeFromRecents="true"
			android:theme="@android:style/Theme.Translucent.NoTitleBar">

			<intent-filter>
				<action android:name="android.intent.action.SEND" />
				<category android:name="android.intent.category.DEFAULT" />
				<data android:mimeType="*/*"/>
			</intent-filter>

			<intent-filter>
				<action android:name="android.intent.action.SEND_MULTIPLE" />
				<category android:name="android.intent.category.DEFAULT" />
				<data android:mimeType="*/*"/>
			</intent-filter>

		</activity>

		<activity
			android:name=".content.UpdaterActivity"
			android:excludeFromRecents="true"
			android:theme="@android:style/Theme.Panel" />

		<service
			android:name=".content.service.PostingService" />

		<receiver
			android:name=".content.service.PostingService$Receiver" />

		<service
			android:name=".content.service.DownloadService" />

		<receiver
			android:name=".content.service.DownloadService$Receiver" />

		<service
			android:name=".content.service.WatcherService" />

		<service
			android:name=".content.service.AudioPlayerService" />

		<service
			android:name=".content.service.webview.WebViewService"
			android:process=":webview" />

		<provider
			android:name=".content.FileProvider"
			android:authorities="${fileProviderAuthority}"
			android:exported="false"
			android:grantUriPermissions="true" />

		<meta-data android:name="com.sec.android.support.multiwindow" android:value="true" />
		<meta-data android:name="com.sec.android.multiwindow.DEFAULT_SIZE_W" android:value="632dp" />
		<meta-data android:name="com.sec.android.multiwindow.DEFAULT_SIZE_H" android:value="598dp" />
		<meta-data android:name="com.sec.android.multiwindow.MINIMUM_SIZE_W" android:value="632dp" />
		<meta-data android:name="com.sec.android.multiwindow.MINIMUM_SIZE_H" android:value="598dp" />

	</application>

</manifest>
