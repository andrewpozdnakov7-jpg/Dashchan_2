# Local signing properties template.
# Reference field names for external or standalone-module signing tools.
# The main Dashchan_2 Gradle project does not load this file automatically.
# Never include a populated copy or a keystore in source archives or commits.
store.file=%PATH_TO_KEYSTORE_FILE%
store.password=%KEYSTORE_PASSWORD%
key.alias=%KEY_ALIAS%
key.password=%KEY_PASSWORD%
