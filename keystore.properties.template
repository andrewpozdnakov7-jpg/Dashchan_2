# Local signing properties template.
# Copy this file to keystore.properties only for experiments with Gradle signing.
# The Dashchan_2 package flow does not require this file; tools/package-dashchan2.ps1
# creates and uses its own local test keystore outside the source tree.
store.file=%PATH_TO_KEYSTORE_FILE%
store.password=%KEYSTORE_PASSWORD%
key.alias=%KEY_ALIAS%
key.password=%KEY_PASSWORD%
